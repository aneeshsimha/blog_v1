---
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import { ClientRouter } from "astro:transitions";
import siteConfig from "../data/site.json";
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const { title = "Aneesh Simha", description = "Builder, writer, and visual experimenter. Exploring ideas at the intersection of technology and creativity." } = Astro.props;
---

<html lang="en" class="h-full antialiased dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title === "Aneesh Simha" ? title : `${title} | Aneesh Simha`}</title>
    <meta name="description" content={description} />
    <ClientRouter />
  </head>
  <body class="flex min-h-full flex-col bg-zinc-950 font-sans text-white">
    <Nav name={siteConfig.name} />
    <main class="flex-1 pt-16">
      <slot />
    </main>
    <Footer socials={siteConfig.socials} />
  </body>
</html>
