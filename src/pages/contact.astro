---
import Base from "../layouts/Base.astro";
import SocialLinks from "../components/SocialLinks.astro";
import siteConfig from "../data/site.json";
---

<Base title="Contact">
  <div class="mx-auto max-w-2xl px-6 py-24">
    <div class="fade-in">
      <h1 class="text-4xl font-bold tracking-tight">Contact</h1>
      <p class="mt-4 leading-relaxed text-zinc-400">
        Want to get in touch? Send me an email or find me on socials.
      </p>
    </div>

    <div class="fade-in" style="animation-delay: 0.1s">
      <div class="mt-12 space-y-8">
        <a
          href={`mailto:${siteConfig.email}`}
          class="inline-flex items-center gap-2 rounded-full bg-white px-6 py-3 text-sm font-medium text-zinc-950 transition-colors hover:bg-zinc-200"
        >
          {siteConfig.email}
        </a>

        <div>
          <h2 class="mb-4 text-sm font-medium uppercase tracking-wider text-zinc-500">
            Elsewhere
          </h2>
          <SocialLinks socials={siteConfig.socials} />
        </div>
      </div>
    </div>
  </div>
</Base>
