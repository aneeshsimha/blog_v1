---
import Base from "../layouts/Base.astro";
import WritingCard from "../components/WritingCard.astro";
import FadeInView from "../components/FadeInView.tsx";
import StaggeredGroup from "../components/StaggeredGroup.tsx";

const writingFiles = import.meta.glob("../data/writings/*.json", { eager: true });
const writings = Object.values(writingFiles)
  .map((mod: any) => mod.default)
  .sort((a: any, b: any) => new Date(b.date).getTime() - new Date(a.date).getTime());
---

<Base title="Writings">
  <div class="mx-auto max-w-2xl px-6 py-24">
    <FadeInView client:visible>
      <h1 class="text-4xl font-bold tracking-tight">Writings</h1>
      <p class="mt-4 text-muted">Thoughts, ideas, and explorations.</p>
    </FadeInView>

    <div class="mt-12">
      {writings.length === 0 ? (
        <p class="text-muted">Posts coming soon. Stay tuned!</p>
      ) : (
        <StaggeredGroup client:visible className="space-y-4" stagger={0.05}>
          {writings.map((w: any) => (
            <WritingCard writing={w} />
          ))}
        </StaggeredGroup>
      )}
    </div>
  </div>
</Base>
