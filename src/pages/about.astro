---
import Base from "../layouts/Base.astro";
import SocialLinks from "../components/SocialLinks.astro";
import FadeInView from "../components/FadeInView.tsx";
import EmojiTooltip from "../components/EmojiTooltip.tsx";
import siteConfig from "../data/site.json";
---

<Base title="About">
  <div class="mx-auto max-w-2xl px-6 py-24">
    <FadeInView client:visible>
      <h1 class="text-4xl font-bold tracking-tight">About</h1>
    </FadeInView>

    <FadeInView client:visible delay={0.1}>
      <div class="mt-8 space-y-6 leading-relaxed text-muted">
        <p>{siteConfig.bio}</p>
        <p>
          Previously, I built data infrastructure and ETL pipelines at <EmojiTooltip client:visible emoji="🏥">Komodo Health</EmojiTooltip> for three years,
          working on the Events Platform Team where we processed vendor data at scale using <EmojiTooltip client:visible emoji="🐍">Python</EmojiTooltip>,
          Snowflake, Airflow, and Spark. Before that I was at <EmojiTooltip client:visible emoji="🔋">Sakuu</EmojiTooltip> building data systems for
          battery R&D, and earlier at TDK Invensense and <EmojiTooltip client:visible emoji="🌐">Cisco</EmojiTooltip>.
        </p>
        <p>
          Outside of work, I experiment with <EmojiTooltip client:visible emoji="🎨">generative art</EmojiTooltip>, build side projects, and write about
          ideas that interest me. This site is a home for all of that.
        </p>
      </div>
    </FadeInView>

    <FadeInView client:visible delay={0.15}>
      <div class="mt-12">
        <h2 class="text-sm font-medium uppercase tracking-wider text-muted">Education</h2>
        <div class="mt-4 space-y-3">
          <div>
            <p class="font-medium">M.S. Computer Science</p>
            <p class="text-sm text-muted"><EmojiTooltip client:visible emoji="☀️">Santa Clara University</EmojiTooltip>, 2020</p>
          </div>
          <div>
            <p class="font-medium">B.S. Materials Science and Engineering</p>
            <p class="text-sm text-muted"><EmojiTooltip client:visible emoji="🌽">University of Illinois at Urbana-Champaign</EmojiTooltip>, 2016</p>
          </div>
        </div>
      </div>
    </FadeInView>

    <FadeInView client:visible delay={0.2}>
      <div class="mt-12">
        <h2 class="text-sm font-medium uppercase tracking-wider text-muted">Experience</h2>
        <div class="mt-4 space-y-4">
          <div>
            <div class="flex items-baseline justify-between">
              <p class="font-medium">Founding Engineer</p>
              <p class="text-sm text-muted">2024 - 2025</p>
            </div>
            <p class="text-sm text-muted">Minerva Data, <EmojiTooltip client:visible emoji="🌉">Brooklyn</EmojiTooltip></p>
          </div>
          <div>
            <div class="flex items-baseline justify-between">
              <p class="font-medium">Software Engineer</p>
              <p class="text-sm text-muted">2021 - 2024</p>
            </div>
            <p class="text-sm text-muted">Komodo Health, <EmojiTooltip client:visible emoji="🗽">New York</EmojiTooltip></p>
          </div>
          <div>
            <div class="flex items-baseline justify-between">
              <p class="font-medium">Software Engineer</p>
              <p class="text-sm text-muted">2021</p>
            </div>
            <p class="text-sm text-muted">Sakuu Inc., San Jose</p>
          </div>
        </div>
      </div>
    </FadeInView>

    <FadeInView client:visible delay={0.25}>
      <div class="mt-12 flex flex-col gap-6">
        <a
          href={siteConfig.resumeUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex w-fit items-center gap-2 rounded-full border border-btn-secondary-border px-5 py-2.5 text-sm font-medium transition-colors hover:border-btn-secondary-hover-border hover:bg-btn-secondary-hover-bg"
        >
          Download Resume
          <span aria-hidden="true">&darr;</span>
        </a>
        <SocialLinks socials={siteConfig.socials} />
      </div>
    </FadeInView>
  </div>
</Base>
