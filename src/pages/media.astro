---
import Base from "../layouts/Base.astro";
import FadeInView from "../components/FadeInView.tsx";
import StaggeredGroup from "../components/StaggeredGroup.tsx";
import { getRecentRatings, getTopRated, parseStars } from "../lib/letterboxd";

const [recentFilms, fiveStarFilms] = await Promise.all([
  getRecentRatings(5),
  getTopRated(5, 3),
]);
---

<Base title="Media">
  <div class="mx-auto max-w-2xl px-6 py-24">
    <FadeInView client:visible>
      <h1 class="text-4xl font-bold tracking-tight">Media</h1>
      <p class="mt-2 text-muted">What I've been watching, pulled live from Letterboxd.</p>
    </FadeInView>

    {/* Five-Star Films */}
    {fiveStarFilms.length > 0 && (
      <FadeInView client:visible delay={0.1}>
        <section class="mt-12">
          <h2 class="text-sm font-medium uppercase tracking-wider text-muted">Five-Star Films</h2>
          <StaggeredGroup client:visible stagger={0.08}>
            <div class="mt-6 grid grid-cols-3 gap-4">
              {fiveStarFilms.map((film) => (
                <a
                  href={film.link}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="group"
                >
                  <div class="overflow-hidden rounded-lg border border-border bg-card-bg transition-colors group-hover:bg-card-hover-bg">
                    {film.posterUrl ? (
                      <img
                        src={film.posterUrl}
                        alt={film.filmTitle}
                        class="aspect-[2/3] w-full object-cover transition-transform duration-300 group-hover:scale-105"
                        loading="lazy"
                      />
                    ) : (
                      <div class="flex aspect-[2/3] w-full items-center justify-center bg-card text-2xl">
                        🎬
                      </div>
                    )}
                    <div class="p-3">
                      <p class="truncate text-sm font-medium">{film.filmTitle}</p>
                      <p class="text-xs text-muted">{film.filmYear}</p>
                      <p class="mt-1 text-xs text-accent">★★★★★</p>
                    </div>
                  </div>
                </a>
              ))}
            </div>
          </StaggeredGroup>
        </section>
      </FadeInView>
    )}

    {/* Recently Watched */}
    <FadeInView client:visible delay={0.2}>
      <section class="mt-16">
        <h2 class="text-sm font-medium uppercase tracking-wider text-muted">Recently Watched</h2>
        <div class="mt-6 space-y-4">
          {recentFilms.map((film, i) => (
            <a
              href={film.link}
              target="_blank"
              rel="noopener noreferrer"
              class="group flex items-center gap-4 rounded-lg border border-border bg-card-bg p-3 transition-colors hover:bg-card-hover-bg"
            >
              {film.posterUrl ? (
                <img
                  src={film.posterUrl}
                  alt={film.filmTitle}
                  class="h-20 w-14 flex-shrink-0 rounded object-cover"
                  loading="lazy"
                />
              ) : (
                <div class="flex h-20 w-14 flex-shrink-0 items-center justify-center rounded bg-card text-lg">
                  🎬
                </div>
              )}
              <div class="min-w-0 flex-1">
                <p class="truncate font-medium">{film.filmTitle}</p>
                <p class="text-sm text-muted">{film.filmYear}</p>
                <div class="mt-1 flex items-center gap-2">
                  <span class="text-sm text-accent">{parseStars(film.rating)}</span>
                  {film.rewatch && (
                    <span class="text-xs text-muted">↻ rewatch</span>
                  )}
                </div>
              </div>
              <span class="hidden text-xs text-muted sm:block">{film.watchedDate}</span>
            </a>
          ))}
        </div>
      </section>
    </FadeInView>

    <FadeInView client:visible delay={0.3}>
      <p class="mt-12 text-center text-xs text-muted">
        Data from <a href="https://letterboxd.com/asimha/" target="_blank" rel="noopener noreferrer" class="text-accent hover:text-accent-hover underline underline-offset-2">Letterboxd</a>
      </p>
    </FadeInView>
  </div>
</Base>
