---
import Base from "../layouts/Base.astro";
import Hero from "../components/Hero.tsx";
import ExperimentCard from "../components/ExperimentCard.astro";
import WritingCard from "../components/WritingCard.astro";
import StaggeredGroup from "../components/StaggeredGroup.tsx";
import FadeInView from "../components/FadeInView.tsx";
import siteConfig from "../data/site.json";

const experimentFiles = import.meta.glob("../data/experiments/*.json", { eager: true });
const writingFiles = import.meta.glob("../data/writings/*.json", { eager: true });

const experiments = Object.values(experimentFiles)
  .map((mod: any) => mod.default)
  .filter((e: any) => e.featured)
  .sort((a: any, b: any) => new Date(b.date).getTime() - new Date(a.date).getTime())
  .slice(0, 3);

const writings = Object.values(writingFiles)
  .map((mod: any) => mod.default)
  .filter((w: any) => w.featured)
  .sort((a: any, b: any) => new Date(b.date).getTime() - new Date(a.date).getTime())
  .slice(0, 3);
---

<Base>
  <Hero client:load site={siteConfig} />

  {experiments.length > 0 && (
    <section class="mx-auto max-w-5xl px-6 py-20">
      <FadeInView client:visible>
        <div class="flex items-end justify-between">
          <div>
            <h2 class="text-2xl font-bold tracking-tight">Experiments</h2>
            <p class="mt-2 text-muted">Things I'm building and exploring.</p>
          </div>
          <a href="/experiments" class="text-sm text-muted transition-colors hover:text-foreground">
            View all &rarr;
          </a>
        </div>
      </FadeInView>
      <StaggeredGroup client:visible className="mt-8 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {experiments.map((exp: any) => (
          <ExperimentCard experiment={exp} />
        ))}
      </StaggeredGroup>
    </section>
  )}

  {writings.length > 0 && (
    <section class="mx-auto max-w-5xl px-6 py-20">
      <FadeInView client:visible>
        <div class="flex items-end justify-between">
          <div>
            <h2 class="text-2xl font-bold tracking-tight">Writings</h2>
            <p class="mt-2 text-muted">Thoughts and ideas.</p>
          </div>
          <a href="/writings" class="text-sm text-muted transition-colors hover:text-foreground">
            View all &rarr;
          </a>
        </div>
      </FadeInView>
      <StaggeredGroup client:visible className="mt-8 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {writings.map((writing: any) => (
          <WritingCard writing={writing} />
        ))}
      </StaggeredGroup>
    </section>
  )}
</Base>
