---
layout: base.njk
title: "projects"
permalink: /projects/
description: "Projects, prototypes, and experiments by Aneesh Simha."
---
<div class="page-head wrap">
  <div class="eyebrow">
    <span>field notes · new york</span>
    <span class="bar"></span>
  </div>
  <h1>projects</h1>
</div>

<section class="wrap">
  <div class="rows">
    {%- for project in collections.projects -%}
      {%- set cat = categories[project.data.category] -%}
      <a class="row" href="{{ project.url }}">
        <span class="row-no">{{ loop.index | pad2 }}</span>
        <span class="row-date">{% if project.data.year %}{{ project.data.year }}{% else %}{{ project.date | dateFormat }}{% endif %}</span>
        <span class="row-main">
          <span class="row-title">{{ project.data.title }}</span>
          {% if project.data.standfirst %}<span class="row-sub">{{ project.data.standfirst }}</span>{% endif %}
        </span>
        <span class="row-cat">{{ cat.label if cat else "" }}</span>
      </a>
    {%- else -%}
      <div class="row"><span class="row-main"><span class="row-title">No projects yet.</span></span></div>
    {%- endfor -%}
  </div>
</section>
