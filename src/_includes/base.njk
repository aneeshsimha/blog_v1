<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ title | default(site.name) }}</title>
  <meta name="description" content="{{ description | default(site.bio) }}">
  <meta property="og:title" content="{{ title | default(site.name) }}">
  <meta property="og:description" content="{{ description | default(site.bio) }}">
  <meta property="og:type" content="website">
  <meta property="og:url" content="https://aneesh.world{{ page.url }}">
  <meta name="twitter:card" content="summary">
  <link rel="canonical" href="https://aneesh.world{{ page.url }}">
  <link rel="preload" href="/fonts/dm-serif-display-latin-400-normal.woff2" as="font" type="font/woff2" crossorigin>
  <link rel="preload" href="/fonts/inter-latin-400-normal.woff2" as="font" type="font/woff2" crossorigin>
  <link rel="stylesheet" href="/css/style.css">
  <link rel="alternate" type="application/atom+xml" href="/feed.xml" title="{{ site.name }}">
</head>
<body class="{{ bodyClass | default('') }}">
  <a href="#main" class="skip-link">Skip to content</a>
  {% include "partials/ambient.njk" %}
  {% include "partials/nav.njk" %}
  <main id="main" class="page-content {{ mainClass | default('') }}">
    {{ content | safe }}
  </main>
  {% include "partials/footer.njk" %}
</body>
</html>
