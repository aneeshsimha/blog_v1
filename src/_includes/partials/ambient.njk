<div class="ambient" aria-hidden="true">
  <div class="ambient__gradient"></div>
  <div class="ambient__drift"></div>
  <div class="ambient__drift ambient__drift--warm"></div>
  <svg class="ambient__grain" width="100%" height="100%">
    <filter id="grain">
      <feTurbulence type="fractalNoise" baseFrequency="0.65" numOctaves="3" stitchTiles="stitch"/>
    </filter>
    <filter id="edge-grain" x="-20%" y="-20%" width="140%" height="140%">
      <feTurbulence type="fractalNoise" baseFrequency="0.12" numOctaves="2" result="noise" />
      <feDisplacementMap in="SourceGraphic" in2="noise" scale="1.5" xChannelSelector="R" yChannelSelector="G" />
    </filter>
    <rect width="100%" height="100%" filter="url(#grain)"/>
  </svg>
  <div class="ambient__glow"></div>
</div>
