---
interface Props {
  writing: {
    title: string;
    slug: string;
    description: string;
    date: string;
    tags: string[];
    link: string;
  };
}

const { writing } = Astro.props;
---

<a
  href={writing.link}
  target="_blank"
  rel="noopener noreferrer"
  class="group block"
>
  <article class="rounded-xl border border-border bg-card-bg p-6 transition-all hover:border-btn-secondary-hover-border hover:bg-card-hover-bg">
    <div class="flex items-center gap-2">
      <time class="font-mono text-xs text-muted">
        {writing.date}
      </time>
      {writing.tags.map((tag: string) => (
        <span class="rounded-full border border-border px-2 py-0.5 text-xs text-muted">
          {tag}
        </span>
      ))}
    </div>
    <h3 class="mt-3 text-lg font-semibold tracking-tight text-foreground transition-colors">
      {writing.title}
    </h3>
    <p class="mt-1.5 line-clamp-2 text-sm leading-relaxed text-muted">
      {writing.description}
    </p>
    <span class="mt-4 inline-flex items-center gap-1 text-sm text-muted transition-colors group-hover:text-foreground">
      Read on Substack
      <svg
        width="14"
        height="14"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        class="transition-transform group-hover:translate-x-0.5"
      >
        <path d="M7 17L17 7M17 7H7M17 7v10" />
      </svg>
    </span>
  </article>
</a>
