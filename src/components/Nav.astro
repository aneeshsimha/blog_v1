---
import NavMobile from "./NavMobile.tsx";

interface Props {
  name: string;
}

const { name } = Astro.props;
const pathname = Astro.url.pathname;

const links = [
  { href: "/", label: "Home" },
  { href: "/experiments", label: "Experiments" },
  { href: "/writings", label: "Writings" },
  { href: "/about", label: "About" },
  { href: "/contact", label: "Contact" },
];
---

<nav class="fixed top-0 z-50 w-full border-b border-zinc-800 bg-zinc-950/80 backdrop-blur-md">
  <div class="mx-auto flex max-w-5xl items-center justify-between px-6 py-4">
    <a href="/" class="font-mono text-sm font-bold uppercase tracking-wider text-white">
      {name}
    </a>

    {/* Desktop */}
    <div class="hidden items-center gap-8 md:flex">
      {links.map((link) => (
        <a
          href={link.href}
          class={`text-sm transition-colors ${
            pathname === link.href
              ? "text-white"
              : "text-zinc-400 hover:text-white"
          }`}
        >
          {link.label}
        </a>
      ))}
    </div>

    {/* Mobile - React island */}
    <NavMobile client:load links={links} pathname={pathname} />
  </div>
</nav>
