---
interface Props {
  experiment: {
    title: string;
    slug: string;
    description: string;
    date: string;
    tags: string[];
    type: string;
    link: string | null;
    thumbnail: string | null;
  };
}

const { experiment } = Astro.props;
const href = experiment.link || `/experiments/${experiment.slug}`;
const isExternal = !!experiment.link;
---

<a
  href={href}
  target={isExternal ? "_blank" : undefined}
  rel={isExternal ? "noopener noreferrer" : undefined}
  class="group block"
>
  <article class="overflow-hidden rounded-xl border border-zinc-800 bg-zinc-900/50 transition-all hover:border-zinc-600 hover:bg-zinc-900">
    {experiment.thumbnail && (
      <div class="relative aspect-video overflow-hidden">
        <img
          src={experiment.thumbnail}
          alt={experiment.title}
          class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
          loading="lazy"
        />
      </div>
    )}
    <div class="p-5">
      <div class="flex items-center gap-2">
        <span class="rounded-full bg-zinc-800 px-2.5 py-0.5 font-mono text-xs text-zinc-400">
          {experiment.type}
        </span>
        <time class="font-mono text-xs text-zinc-500">
          {experiment.date}
        </time>
      </div>
      <h3 class="mt-3 text-lg font-semibold tracking-tight text-white transition-colors group-hover:text-zinc-200">
        {experiment.title}
      </h3>
      <p class="mt-1.5 line-clamp-2 text-sm leading-relaxed text-zinc-400">
        {experiment.description}
      </p>
      {experiment.tags.length > 0 && (
        <div class="mt-3 flex flex-wrap gap-1.5">
          {experiment.tags.map((tag: string) => (
            <span class="rounded-full border border-zinc-800 px-2 py-0.5 text-xs text-zinc-500">
              {tag}
            </span>
          ))}
        </div>
      )}
    </div>
  </article>
</a>
